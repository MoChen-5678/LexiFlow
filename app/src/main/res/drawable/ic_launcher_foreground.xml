<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Subtle Drop Shadow under the entire book assembly -->
    <path
        android:fillColor="#15000000"
        android:pathData="M18,78 C18,78 36,82 54,86 C72,82 90,78 90,78 L90,80 C90,80 72,84 54,88 C36,84 18,80 18,80 Z" />

    <!-- Open Book Cyan/Teal Under-Cover Layers -->
    <path
        android:fillColor="#004D40"
        android:pathData="M19,74 C19,74 36,78 54,82 C72,78 89,74 89,74 L89,76 C89,76 72,80 54,84 C36,80 19,76 19,76 Z" />
    <path
        android:fillColor="#00E5FF"
        android:pathData="M19,71 C19,71 36,75 54,79 C72,75 89,71 89,71 L89,74 C89,74 72,78 54,82 C36,78 19,74 19,74 Z" />
    <path
        android:fillColor="#B2EBF2"
        android:pathData="M20,68 C20,68 36,72 54,76 C72,72 88,68 88,68 L88,71 C88,71 72,75 54,79 C36,75 20,71 20,71 Z" />

    <!-- Open Book White Pages -->
    <path
        android:fillColor="#ECEFF1"
        android:pathData="M21,62 C21,62 36,65 54,69 C72,65 87,62 87,62 L87,67 C87,67 72,70 54,74 C36,70 21,67 21,67 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M21,59 C21,59 36,62 54,66 C72,62 87,59 87,59 L87,62 C87,62 72,65 54,69 C36,65 21,62 21,62 Z" />

    <!-- Main Serif Letter L (centered, high-contrast white) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M38,20 L51,20 L51,23 L47,23 C45.5,23 45,23.5 45,25 
            L45,46 L45,49 C45,50.5 45.5,51 47,51 L58,51 L62,51 
            C65,51 66.5,50 68,44 L71,44 L68,55 L38,55 
            L38,52 L41,52 C42.5,52 43,51.5 43,50 L43,25 
            C43,23.5 42.5,23 41,23 L38,23 Z
        " />

    <!-- Flowing S-Ribbon/Stream wrapping around the Letter L -->
    <!-- Lower Cyan Loop starting from book center fold and curling up-left -->
    <path
        android:pathData="M54,64 C46,56 29,51 29,42 C29,35 40,33 46,33 C40,35 32,37 32,42 C32,49 46,53 54,64 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="29"
                android:startY="64"
                android:endX="54"
                android:endY="33"
                android:type="linear">
                <item android:color="#00E5FF" android:offset="0.0" />
                <item android:color="#00B0FF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Upper Blue Loop crossing in front of the Letter L to complete the S-curve -->
    <path
        android:pathData="M29,42 C29,34 41,33 52,36 C58,38 63,41 63,45 C63,50 57,52 52,52 C57,52 60,49 60,45 C60,42 56,39 52,37 C42,35 32,36 32,42 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="29"
                android:startY="42"
                android:endX="63"
                android:endY="45"
                android:type="linear">
                <item android:color="#00B0FF" android:offset="0.0" />
                <item android:color="#4FC3F7" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
